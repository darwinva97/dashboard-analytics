---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import TopBar from '../components/TopBar.astro';

const orderStats = [
  { label: 'Total Hoy', value: '147', icon: 'clipboard', color: 'var(--accent)' },
  { label: 'Pendientes', value: '12', icon: 'clock', color: 'var(--warning)' },
  { label: 'En Preparación', value: '8', icon: 'fire', color: 'var(--accent-2)' },
  { label: 'Completados', value: '118', icon: 'check', color: 'var(--success)' },
  { label: 'Cancelados', value: '9', icon: 'x', color: 'var(--danger)' },
];

const tabs = ['Todos', 'Pendientes', 'En Preparación', 'Completados', 'Cancelados'];

const orders = [
  { id: '#1852', client: 'María García', items: 'Lomo Saltado, Chicha Morada', qty: 2, total: 'S/ 68.00', status: 'Completado', statusClass: 'badge-success', time: '14:32', mesa: 'Mesa 5' },
  { id: '#1851', client: 'Juan Rodríguez', items: 'Ceviche Clásico x2, Pisco Sour', qty: 3, total: 'S/ 124.00', status: 'En Preparación', statusClass: 'badge-warning', time: '14:28', mesa: 'Mesa 12' },
  { id: '#1850', client: 'Rosa Huamán', items: 'Ají de Gallina, Limonada', qty: 2, total: 'S/ 42.50', status: 'Entregado', statusClass: 'badge-info', time: '14:15', mesa: 'Mesa 3' },
  { id: '#1849', client: 'Pedro Quispe', items: 'Arroz con Mariscos, Cerveza', qty: 2, total: 'S/ 58.00', status: 'Completado', statusClass: 'badge-success', time: '14:05', mesa: 'Mesa 8' },
  { id: '#1848', client: 'Ana Flores', items: 'Causa Limeña, Suspiro Limeño', qty: 2, total: 'S/ 45.00', status: 'Cancelado', statusClass: 'badge-danger', time: '13:52', mesa: 'Mesa 2' },
  { id: '#1847', client: 'Carlos Vargas', items: 'Pollo a la Brasa, Papas, Inca Kola', qty: 3, total: 'S/ 72.00', status: 'Entregado', statusClass: 'badge-info', time: '13:45', mesa: 'Mesa 15' },
  { id: '#1846', client: 'Lucía Mendoza', items: 'Tacu Tacu con Lomo', qty: 1, total: 'S/ 52.00', status: 'Completado', statusClass: 'badge-success', time: '13:30', mesa: 'Mesa 6' },
  { id: '#1845', client: 'Fernando Castillo', items: 'Seco de Cordero, Chicha', qty: 2, total: 'S/ 55.50', status: 'Completado', statusClass: 'badge-success', time: '13:18', mesa: 'Mesa 10' },
  { id: '#1844', client: 'Gabriela Torres', items: 'Anticuchos, Papa a la Huancaína', qty: 2, total: 'S/ 38.00', status: 'Completado', statusClass: 'badge-success', time: '13:05', mesa: 'Mesa 4' },
  { id: '#1843', client: 'Miguel Paredes', items: 'Chifa Aeropuerto, Wantán Frito', qty: 2, total: 'S/ 46.00', status: 'Entregado', statusClass: 'badge-info', time: '12:50', mesa: 'Mesa 7' },
  { id: '#1842', client: 'Sofía Ramos', items: 'Tiradito de Lenguado, Leche de Tigre', qty: 2, total: 'S/ 62.00', status: 'Completado', statusClass: 'badge-success', time: '12:38', mesa: 'Mesa 9' },
  { id: '#1841', client: 'Diego Morales', items: 'Rocoto Relleno, Solterito', qty: 2, total: 'S/ 48.00', status: 'Cancelado', statusClass: 'badge-danger', time: '12:25', mesa: 'Mesa 1' },
  { id: '#1840', client: 'Valentina Díaz', items: 'Tallarines Verdes con Bistec', qty: 1, total: 'S/ 35.00', status: 'Completado', statusClass: 'badge-success', time: '12:10', mesa: 'Mesa 11' },
  { id: '#1839', client: 'Alejandro Soto', items: 'Papa Rellena x2, Emoliente', qty: 3, total: 'S/ 28.00', status: 'Completado', statusClass: 'badge-success', time: '11:55', mesa: 'Mesa 14' },
];
---

<Layout title="GastroMetrics - Pedidos">
  <div class="dashboard-layout">
    <Sidebar activePage="pedidos" />
    <div class="main-content">
      <TopBar pageTitle="Pedidos" />
      <div class="page-content">

        <!-- Order Stats -->
        <div class="order-stats">
          {orderStats.map((stat) => (
            <div class="order-stat-card">
              <div class="order-stat-icon" style={`background: ${stat.color}20; color: ${stat.color};`}>
                <span class="order-stat-value">{stat.value}</span>
              </div>
              <span class="order-stat-label">{stat.label}</span>
            </div>
          ))}
        </div>

        <!-- Filter Tabs -->
        <div class="tabs mt-3">
          {tabs.map((tab, i) => (
            <div class={`tab ${i === 0 ? 'active' : ''}`}>{tab}</div>
          ))}
        </div>

        <!-- Orders Table -->
        <div class="card">
          <div class="card-title">
            <span>Lista de Pedidos</span>
            <span class="text-xs text-muted">Mostrando {orders.length} pedidos</span>
          </div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Pedido</th>
                  <th>Cliente</th>
                  <th>Mesa</th>
                  <th>Items</th>
                  <th>Cant.</th>
                  <th>Total</th>
                  <th>Estado</th>
                  <th>Hora</th>
                </tr>
              </thead>
              <tbody>
                {orders.map((order) => (
                  <tr>
                    <td class="order-id">{order.id}</td>
                    <td class="font-semibold">{order.client}</td>
                    <td class="text-muted">{order.mesa}</td>
                    <td class="order-items-cell">{order.items}</td>
                    <td>{order.qty}</td>
                    <td class="font-semibold">{order.total}</td>
                    <td><span class={`badge ${order.statusClass}`}>{order.status}</span></td>
                    <td class="text-muted">{order.time}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .order-stats {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .order-stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 140px;
    transition: border-color 0.2s;
  }

  .order-stat-card:hover {
    border-color: rgba(108, 92, 231, 0.3);
  }

  .order-stat-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .order-stat-value {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .order-stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .order-id {
    font-weight: 600;
    color: var(--accent);
  }

  .order-items-cell {
    max-width: 250px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .order-stats {
      flex-direction: column;
    }
  }
</style>
