---
const dishes = [
  { rank: 1, name: 'Lomo Saltado', orders: 234, revenue: 'S/ 9,360', percent: 100 },
  { rank: 2, name: 'Ceviche Clásico', orders: 198, revenue: 'S/ 8,910', percent: 85 },
  { rank: 3, name: 'Ají de Gallina', orders: 176, revenue: 'S/ 6,160', percent: 75 },
  { rank: 4, name: 'Arroz con Mariscos', orders: 152, revenue: 'S/ 7,600', percent: 65 },
  { rank: 5, name: 'Causa Limeña', orders: 143, revenue: 'S/ 4,290', percent: 61 },
];
---

<div class="card">
  <div class="card-title">
    <span>Platos Populares</span>
    <span class="text-xs text-muted">Este mes</span>
  </div>

  <div class="dishes-list">
    {dishes.map((dish) => (
      <div class="dish-item">
        <div class="dish-rank">#{dish.rank}</div>
        <div class="dish-info">
          <div class="dish-header">
            <span class="dish-name">{dish.name}</span>
            <span class="dish-revenue">{dish.revenue}</span>
          </div>
          <div class="dish-meta">
            <span>{dish.orders} pedidos</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" style={`width: ${dish.percent}%;`}></div>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .dishes-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .dish-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .dish-item:not(:last-child) {
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }

  .dish-rank {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    background: rgba(108, 92, 231, 0.1);
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .dish-info {
    flex: 1;
    min-width: 0;
  }

  .dish-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.15rem;
  }

  .dish-name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .dish-revenue {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--success);
  }

  .dish-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .progress-bar {
    height: 4px;
  }
</style>
